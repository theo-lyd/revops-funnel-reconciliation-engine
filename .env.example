ENVIRONMENT=dev
DUCKDB_PATH=./data/warehouse/revops.duckdb
DBT_THREADS_LOCAL=1
DBT_THREADS_PROD=4
DBT_MAX_THREADS_LOCAL=2
DBT_MAX_THREADS_PROD=4
DBT_TIMEOUT_SECONDS_LOCAL=900
DBT_TIMEOUT_SECONDS_PROD=1800
COST_LOOKBACK_HOURS=24
COST_MAX_QUERIES=2000
COST_QUERY_TAG_PREFIX=
COST_ATTRIBUTION_REPORT_PATH=artifacts/performance/query_cost_attribution_report.json
COST_BASELINE_REPORT_PATH=artifacts/performance/query_cost_attribution_baseline.json
COST_REGRESSION_REPORT_PATH=artifacts/performance/query_cost_regression_report.json
COST_MAX_CREDITS_REGRESSION_PCT=20
COST_MAX_ELAPSED_REGRESSION_PCT=25
COST_REGRESSION_STRICT=false

# Phase 9: Health Monitoring and Observability
HEALTH_MAX_FRESHNESS_HOURS=24
HEALTH_MAX_JOB_DURATION_MINUTES=120
HEALTH_REPORT_PATH=artifacts/monitoring/health_report.json
HEALTH_STRICT_METRICS=false

# Phase 9: Operational Dashboards and SLO/SLI Tracking
DASHBOARD_OUTPUT_PATH=artifacts/monitoring/operational_dashboard.json
DASHBOARD_HEALTH_REPORT=artifacts/monitoring/health_report.json
DASHBOARD_COST_REPORT=artifacts/monitoring/query_cost_attribution.json
DASHBOARD_PERFORMANCE_REPORT=artifacts/performance/dbt_build_prod_report.json

# Phase 9: On-Call Runbooks and Escalation Procedures
ONCALL_RUNBOOK_REPORT_PATH=artifacts/runbooks/oncall_runbook_report.json
ONCALL_HEALTH_REPORT=artifacts/monitoring/health_report.json
ONCALL_DASHBOARD_REPORT=artifacts/monitoring/operational_dashboard.json
ONCALL_ROLLBACK_REPORT=artifacts/promotions/deployment_rollback_execution.json
ONCALL_INCIDENT_DISPATCH_REPORT=artifacts/promotions/rollback_incident_dispatch.json
ONCALL_DEAD_LETTER_ESCALATION_REPORT=artifacts/promotions/rollback_dead_letter_escalation.json
ONCALL_PRIMARY_ENDPOINT=pagerduty-primary
ONCALL_SECONDARY_ENDPOINT=pagerduty-secondary
ONCALL_TICKET_QUEUE=revops-platform

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_DATABASE=REVOPS
SNOWFLAKE_WAREHOUSE=TRANSFORMING
SNOWFLAKE_SCHEMA=analytics
SNOWFLAKE_GOLD_SCHEMA=analytics_gold
DBT_QUERY_TAG=revops_funnel_prod
PARITY_TOLERANCE=0.02
PARITY_TOLERANCE_STRICT=0.0
PARITY_REPORT_PATH=artifacts/parity/metric_parity_report.json
RELEASE_ID=
RELEASE_ALLOWED_ACTORS=
ROLLBACK_ALLOWED_ACTORS=
ROLLBACK_EXECUTION_ENABLED=false
ROLLBACK_INCIDENT_WEBHOOK_URL=
ROLLBACK_INCIDENT_WEBHOOK_TOKEN=
ROLLBACK_INCIDENT_STRICT=false
ROLLBACK_INCIDENT_MAX_ATTEMPTS=3
ROLLBACK_INCIDENT_BACKOFF_SECONDS=2
ROLLBACK_ESCALATION_WEBHOOK_URL=
ROLLBACK_ESCALATION_WEBHOOK_TOKEN=
ROLLBACK_ESCALATION_STRICT=false
ROLLBACK_ESCALATION_MAX_ATTEMPTS=2
ROLLBACK_ESCALATION_BACKOFF_SECONDS=3

# Phase 5: Dashboard and BI Configuration
METABASE_HOST=http://localhost
METABASE_PORT=3000
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=
METABASE_DUCKDB_DATA_SOURCE_NAME=DuckDB Local
METABASE_SNOWFLAKE_DATA_SOURCE_NAME=Snowflake Production
STREAMLIT_SERVER_PORT=8501
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_MAX_QUERY_ROWS=5000
DASHBOARD_CACHE_SECONDS=300
BI_CONSUMPTION_SCHEMA=analytics_gold

# Phase 5.3: LLM orchestration and guardrails
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=600
LLM_RATE_LIMIT_PER_MINUTE=10
LLM_AUDIT_LOG_PATH=artifacts/ai/llm_query_audit.jsonl

# Phase 5.4: Anomaly detection and monitoring
ANOMALY_DETECTION_SENSITIVITY=2.0
ANOMALY_CHECK_CADENCE_HOURS=24
MONITORING_DASHBOARD_REFRESH_INTERVAL=300
ALERT_EMAIL_RECIPIENTS=stakeholder@example.com
ANOMALY_REPORT_PATH=artifacts/monitoring/anomaly_report.json
ANOMALY_MARKDOWN_PATH=artifacts/monitoring/anomaly_report.md

# Reporting pack packaging
REPORTING_PACK_OUTPUT_PATH=artifacts/reports/public_sector_executive_reporting_pack.json
REPORTING_PACK_VERSION=1.0.0
