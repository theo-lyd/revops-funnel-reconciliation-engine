ENVIRONMENT=dev
DUCKDB_PATH=./data/warehouse/revops.duckdb
DBT_THREADS_LOCAL=1
DBT_THREADS_PROD=4

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_DATABASE=REVOPS
SNOWFLAKE_WAREHOUSE=TRANSFORMING
SNOWFLAKE_SCHEMA=analytics
SNOWFLAKE_GOLD_SCHEMA=analytics_gold
DBT_QUERY_TAG=revops_funnel_prod
PARITY_TOLERANCE=0.02
PARITY_TOLERANCE_STRICT=0.0
PARITY_REPORT_PATH=artifacts/parity/metric_parity_report.json
RELEASE_ID=
RELEASE_ALLOWED_ACTORS=
ROLLBACK_ALLOWED_ACTORS=
ROLLBACK_EXECUTION_ENABLED=false
ROLLBACK_INCIDENT_WEBHOOK_URL=
ROLLBACK_INCIDENT_WEBHOOK_TOKEN=
ROLLBACK_INCIDENT_STRICT=false
ROLLBACK_INCIDENT_MAX_ATTEMPTS=3
ROLLBACK_INCIDENT_BACKOFF_SECONDS=2

# Phase 5: Dashboard and BI Configuration
METABASE_HOST=http://localhost
METABASE_PORT=3000
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=
METABASE_DUCKDB_DATA_SOURCE_NAME=DuckDB Local
METABASE_SNOWFLAKE_DATA_SOURCE_NAME=Snowflake Production
STREAMLIT_SERVER_PORT=8501
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_MAX_QUERY_ROWS=5000
DASHBOARD_CACHE_SECONDS=300
BI_CONSUMPTION_SCHEMA=analytics_gold

# Phase 5.3: LLM orchestration and guardrails
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=600
LLM_RATE_LIMIT_PER_MINUTE=10
LLM_AUDIT_LOG_PATH=artifacts/ai/llm_query_audit.jsonl

# Phase 5.4: Anomaly detection and monitoring
ANOMALY_DETECTION_SENSITIVITY=2.0
ANOMALY_CHECK_CADENCE_HOURS=24
MONITORING_DASHBOARD_REFRESH_INTERVAL=300
ALERT_EMAIL_RECIPIENTS=stakeholder@example.com
ANOMALY_REPORT_PATH=artifacts/monitoring/anomaly_report.json
ANOMALY_MARKDOWN_PATH=artifacts/monitoring/anomaly_report.md
